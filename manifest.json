{
  "manifest_version": 3,
  "name": "Modrinth Extras",
  "version": "1.0",
  "description": "Adds a red border to all webpages matching mozilla.org.",

  "permissions": ["activeTab", "scripting"],

  "content_scripts": [
    {
      "matches": ["*://*.modrinth.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "modrinth-extras@anvar.me"
    }
  }
}