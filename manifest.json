{
  "manifest_version": 3,
  "name": "Modrinth Extras",
  "version": "1.0",
  "description": "Adds some extra features for Modrinth website",
  "author": "Anvar",
  "permissions": [],

  "content_scripts": [
    {
      "matches": ["*://modrinth.com/*"],
      "js": ["content.js"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "modrinth-extras@anvar.me",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}